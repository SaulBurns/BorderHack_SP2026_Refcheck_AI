# RefCheck AI backend environment variables

APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# mock keeps the app demo-safe without paid keys.
# Use anthropic for the real four-agent Claude pipeline.
# openai is not wired for the four-agent mode yet and will fall back to mock.
AI_PROVIDER=mock

# Anthropic option:
# AI_PROVIDER=anthropic
# AI_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=your_anthropic_key

# OpenAI option:
# AI_PROVIDER=openai
# AI_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=your_openai_key
